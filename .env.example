# ============================================
# YEO - Environment Variables
# ============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Google OAuth: add redirect URL in Supabase Auth → URL configuration, e.g.
# https://yeonote.vercel.app/auth/callback (production) and http://localhost:3000/auth/callback (dev)

# --- OpenAI ---
OPENAI_API_KEY=your_openai_api_key

# --- Lemon Squeezy (one product, Pro + Team variants = one-time credit packs) ---
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key
# Numeric store id (API / dashboard reference). Not used as checkout subdomain.
LEMONSQUEEZY_STORE_ID=your_numeric_store_id
# Optional: store subdomain (dashboard only). Checkout URLs come from POST /v1/checkouts API.
LEMONSQUEEZY_STORE_SLUG=your-store-slug
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret
# Single catalog product id (Pro / Team use variants of this product)
LEMONSQUEEZY_PRODUCT_ID=1015439
# Variant ids for one-time credit packs (POST /v1/checkouts)
LEMONSQUEEZY_VARIANT_ID_PRO=your_pro_variant_id
LEMONSQUEEZY_VARIANT_ID_TEAM=your_team_variant_id
# Optional: pre-built customer billing portal URL
LEMONSQUEEZY_BILLING_PORTAL_URL=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=YEO

# --- Analytics (Optional) ---
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Rate Limiting (optional; AI routes skip limiter if unset) ---
UPSTASH_REDIS_REST_URL=your_upstash_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# --- Email (Optional, for notifications) ---
RESEND_API_KEY=your_resend_api_key
