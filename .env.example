# ============================================
# YEO - Environment Variables
# ============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- OpenAI ---
OPENAI_API_KEY=your_openai_api_key

# --- Lemon Squeezy (one product, multiple variants) ---
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key
# Numeric store id (API / dashboard reference). Not used as checkout subdomain.
LEMONSQUEEZY_STORE_ID=your_numeric_store_id
# Store slug for checkout: https://[slug].lemonsqueezy.com/buy/[variant-id]
LEMONSQUEEZY_STORE_SLUG=your-store-slug
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret
# Single catalog product id (all plans use variants of this product)
LEMONSQUEEZY_PRODUCT_ID=1015439
# Variant ids for Free / Pro / Team on that product
LEMONSQUEEZY_VARIANT_ID_FREE=your_free_variant_id
LEMONSQUEEZY_VARIANT_ID_PRO=your_pro_variant_id
LEMONSQUEEZY_VARIANT_ID_TEAM=your_team_variant_id
# Optional: pre-built customer billing portal URL
LEMONSQUEEZY_BILLING_PORTAL_URL=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=YEO

# --- Analytics (Optional) ---
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Rate Limiting (optional; AI routes skip limiter if unset) ---
UPSTASH_REDIS_REST_URL=your_upstash_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# --- Email (Optional, for notifications) ---
RESEND_API_KEY=your_resend_api_key
